# =============================================================================
# .env.example — template for environment secrets
# =============================================================================
# This file IS committed to git as a reference.
# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — real secrets never enter the repo.
# =============================================================================

# -----------------------------------------------------------------------------
# Azure SQL Database (Phase 1 — source database)
# -----------------------------------------------------------------------------
AZURE_SQL_SERVER=sql-retail-demand-fc-phm.database.windows.net
AZURE_SQL_DATABASE=sqldb-m5-source
AZURE_SQL_USER=sqladmin
AZURE_SQL_PASSWORD=__SET_IN_DOT_ENV__

# -----------------------------------------------------------------------------
# Snowflake (Phase 2 — cloud warehouse)
# -----------------------------------------------------------------------------
# Filled in when we sign up for the Snowflake trial.
SNOWFLAKE_ACCOUNT=ghrcrqs-hw63290
SNOWFLAKE_USER=PHELUCIAM
SNOWFLAKE_PASSWORD=__SET_IN_DOT_ENV__
SNOWFLAKE_WAREHOUSE=WH_RETAIL
SNOWFLAKE_DATABASE=RETAIL_DB
SNOWFLAKE_SCHEMA=RAW
SNOWFLAKE_ROLE=RETAIL_ENGINEER

# -----------------------------------------------------------------------------
# Kaggle API (Phase 1 — M5 dataset download)
# -----------------------------------------------------------------------------
# Token is normally read from C:\Users\<you>\.kaggle\kaggle.json automatically,
# so usually nothing needed here. Keep these for reference in case we override.
KAGGLE_USERNAME=
KAGGLE_KEY=
